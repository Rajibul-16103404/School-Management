# Disable execution of scripts in the uploads folder
<FilesMatch "\.(php|php3|php4|php5|php7|php8|phtml|pl|py|jsp|asp|sh|cgi|exe)$">
    Order Deny,Allow
    Deny from all
</FilesMatch>

# Turn off script execution and directory listing
Options -ExecCGI -Indexes
Header set X-Content-Type-Options "nosniff"
